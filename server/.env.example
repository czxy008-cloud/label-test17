# ========================================
# 服务器配置
# ========================================
PORT=3001
CORS_ORIGIN=http://localhost:3000

# ========================================
# PostgreSQL 数据库配置
# ========================================
DB_USER=postgres
DB_HOST=localhost
DB_NAME=whiteboard_db
DB_PASSWORD=postgres
DB_PORT=5432

# ========================================
# 会话配置
# ========================================
SESSION_SECRET=your-secret-key-change-in-production

# ========================================
# 日志配置
# ========================================
LOG_LEVEL=debug
